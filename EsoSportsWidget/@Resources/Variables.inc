[Variables]
; ============================
; Eso Sports Widget - Settings
; ============================

; Leagues to show (1=on, 0=off)
ShowNBA=1
ShowNFL=1
ShowNCAAM=1
ShowMLB=1

; Favorite teams (comma-separated abbreviations)
; NBA: LAL, BOS, GSW, MIL, NYK, BKN, PHI, MIA, CHI, CLE, etc.
; NFL: KC, SF, DAL, PHI, BUF, DET, BAL, MIA, CIN, etc.
; NCAAM: DUKE, UNC, UK, KU, GONZ, PURDUE, UCONN, etc.
; MLB: NYY, BOS, NYM, LAD, HOU, ATL, SEA, etc.
; Use LEAGUE:ABBR prefix for ambiguous abbreviations (e.g., NFL:SEA, MLB:SEA)
FavoriteTeams=NFL:SEA,GONZ,MLB:SEA

; Refresh interval in minutes
RefreshMinutes=5

; Timezone UTC offset (e.g., -8 for PST, -5 for EST, 0 for UTC)
TimezoneOffset=-8

; Display
MaxGamesPerLeague=12
FontFace=Segoe UI
FontSize=11
HeaderFontSize=14
TextColor=220,220,220
HeaderColor=255,255,255
AccentColor=0,150,255
NBAColor=255,100,50
NFLColor=0,180,100
NCAAMColor=80,150,255
MLBColor=0,90,180
LiveColor=50,205,50
DimColor=120,120,120
BackgroundColor=20,20,30,220
RowHeight=16
SkinWidth=380

; Scroll
ScrollOffset=0
ScrollStep=28
MaxSkinHeight=600

; Internal - do not edit
FavCount=0
NBAGameCount=0
NFLGameCount=0
NCAAMGameCount=0
MLBGameCount=0
