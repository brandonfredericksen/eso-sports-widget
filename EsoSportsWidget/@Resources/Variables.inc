[Variables]
; ============================
; Eso Sports Widget - Defaults
; ============================
; To customize, edit UserSettings.inc (right-click widget > Edit Settings)

; Leagues to show (1=on, 0=off)
ShowNBA=1
ShowNFL=1
ShowNCAAM=1
ShowMLB=1
ShowUFC=1
ShowBKFC=1
ShowSMX=1
ShowF1=1

; Display order (comma-separated, controls fetch chain and layout order)
LeagueOrder=NBA,NFL,NCAAM,MLB,UFC,BKFC,SMX,F1

; Favorite teams (comma-separated abbreviations)
; NBA: LAL, BOS, GSW, MIL, NYK, BKN, PHI, MIA, CHI, CLE, etc.
; NFL: KC, SF, DAL, PHI, BUF, DET, BAL, MIA, CIN, etc.
; NCAAM: DUKE, UNC, UK, KU, GONZ, PURDUE, UCONN, etc.
; MLB: NYY, BOS, NYM, LAD, HOU, ATL, SEA, etc.
; Use LEAGUE:ABBR prefix for ambiguous abbreviations (e.g., NFL:SEA, MLB:SEA)
FavoriteTeams=

; Refresh interval in minutes
RefreshMinutes=5

; Timezone UTC offset (e.g., -8 for PST, -5 for EST, 0 for UTC)
TimezoneOffset=0

; Display
MaxGamesPerLeague=30
MaxVisiblePerLeague=10
FontFace=Segoe UI
FontSize=11
HeaderFontSize=14
TextColor=220,220,220
HeaderColor=255,255,255
AccentColor=0,150,255
NBAColor=255,100,50
NFLColor=0,180,100
NCAAMColor=80,150,255
MLBColor=0,90,180
UFCColor=200,0,0
BKFCColor=220,180,50
SMXColor=0,210,190
F1Color=225,6,0
LiveColor=50,205,50
DimColor=120,120,120
BackgroundColor=20,20,30,220
RowHeight=16
SkinWidth=380

; Scroll
ScrollOffset=0
ScrollStep=84
MaxSkinHeight=600

; Internal - do not edit
FavCount=0
NBAGameCount=0
NFLGameCount=0
NCAAMGameCount=0
MLBGameCount=0
UFCGameCount=0
BKFCGameCount=0
SMXGameCount=0
F1GameCount=0
